# Firebase (client) — from Firebase Console → Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Firebase Admin (server auth) — JSON key as a single line, or path to key file
FIREBASE_SERVICE_ACCOUNT_KEY=

# OpenAI for AI-powered outfit recommendations
OPENAI_API_KEY=

# Optional: CV service URL (e.g. https://your-cv-service.onrender.com) for photo analysis
CV_SERVICE_URL=

# Gemini API key for the per-interaction "why" inference (lib/gemini inferWhyForInteraction).
# Optional — absent key makes the path no-op. GEMINI_MODEL overrides the default gemini-2.5-flash-lite.
GEMINI_API_KEY=
GEMINI_MODEL=
