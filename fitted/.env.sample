# Firebase (client) — from Firebase Console → Project settings
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Firebase Admin (server auth) — JSON key as a single line, or path to key file
FIREBASE_SERVICE_ACCOUNT_KEY=

# OpenAI (the gpt-5.4-mini stylist). NOTE: after the C8 legacy retirement the Next app no longer
# reads this — the key is held service-side by the Fly render service. This row is removed at the
# C8 half-2 flag flip (which adds ML_SERVICE_URL / FITTED_SERVICE_KEY). See CLAUDE.md env table.
OPENAI_API_KEY=

# Optional: CV service URL (e.g. https://your-cv-service.onrender.com) for photo analysis
CV_SERVICE_URL=

# --- M5 C8 half-2 (render-service cutover): uncomment + fill at the flag flip. See
#     docs/plans/m5-c8-half2-runbook.md. Until the flip, the recommend route returns the §A
#     degraded empty state (USE_ML_SHORTLISTER off/unset). ---
# ML_SERVICE_URL=https://fitted-render-service.fly.dev
# FITTED_SERVICE_KEY=            # MUST equal the service's SERVICE_KEY_CURRENT (same value, different var name)
# ML_SERVICE_TIMEOUT_MS=45000    # optional (default 45000; keep < the route's 60s maxDuration budget)
# USE_ML_SHORTLISTER=true        # THE FLIP — off/unset = §A degraded empty state
