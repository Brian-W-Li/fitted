# H26 spike — keep large/raw/secret artifacts out of git (§14 PII, §8 raw payloads).

# Dataset bundle (Polyvore-Disjoint: multi-GB images + JSON). Brian provides it locally;
# data_loader.py reads $H26_DATA_ROOT (default ./data/polyvore_outfits/). Never commit.
data/
# Extension backstop (second layer under the closet/ + data/ dir guards): catch a stray photo
# saved OUTSIDE those dirs. Cover the iPhone default (HEIC/HEIF) + WebP + common formats,
# case-insensitively — the §10/§14 protocol collects real face-bearing phone photos, so a leak
# here is irreversible in a public repo.
*.jpg
*.jpeg
*.png
*.JPG
*.JPEG
*.PNG
*.heic
*.heif
*.HEIC
*.HEIF
*.webp
*.WEBP
*.gif
*.bmp
*.tif
*.tiff

# Embedding cache (§5 embedding_manifest.json freezes the hashes; the cache blobs stay out).
*.npy
*.npz
.cache/
embeddings/

# Trained-head checkpoints (C3 train_head.py). selection.json commits the checkpoint HASH + config
# + manifest binding; the .pt weight blob is regenerable bit-for-bit from the seed (like the
# embedding cache), so it stays out of git. selection.json itself IS committed.
checkpoints/
*.pt

# Raw judge payloads + images sent to the API (§8/§14 — only the de-identified
# judge_runs.ndjson ledger is committed; raw request/response payloads are not).
raw_payloads/
*.payload.json

# Closet probe photos (§10/§14 — local, consented, redacted; never egress to git).
closet/

# RUN-phase scratch (regenerable). The COMMITTED artifacts are judge_runs.ndjson (gate-B ledger),
# calibration_set.json (unlock-bound), closet_manifest.json, selection.json, metrics.json — NOT these.
# NOTE: git only treats `#` as a comment at the START of a line — an inline `#` becomes literal pattern
# text and silently un-ignores the file, so every comment below is on its own line (a mid-line comment
# here once un-ignored closet_input.json + the viewer blob; keep the patterns bare).
# large (embeds base64 catalog images); regenerate with make_calibration.py
calibration_viewer.html
# your raw viewer picks; folded into calibration_set.json by finalize()
calibration_answers.json
# a second re-label pass over a subset (intra-annotator stability, §8); folded by restability()
calibration_answers_recheck.json
# the drawn calibration questions cache (regenerable from the seed)
calibration_questions.json
# throwaway judge calibration pilot (K sweep) — never committed
calibration_pilot.ndjson
# your raw label input; folded into closet_manifest.json by assemble_closet.py
closet_input.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
